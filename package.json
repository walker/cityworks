{
  "name": "cityworks",
  "version": "2.2.20",
  "description": "A Cityworks API wrapper",
  "main": "dist/index.js",
  "umd:main": "dist/index.umd.js",
  "module": "dist/index.m.js",
  "source": "src/index.ts",
  "files": [
    "dist/*"
  ],
  "directories": {
    "test": "test"
  },
  "scripts": {
    "dev": "microbundle watch",
    "build": "microbundle",
    "test": "mocha -R spec --recursive ./test/ -g ",
    "fulltest": "mocha -R spec --recursive ./test/",
    "docs": "typedoc --tsconfig ./tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/walker/cityworks.git"
  },
  "keywords": [
    "cityworks",
    "api",
    "wrapper",
    "government",
    "local",
    "asset"
  ],
  "author": "Walker",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/walker/cityworks/issues"
  },
  "homepage": "https://walker.github.io/cityworks/",
  "devDependencies": {
    "chai": "~6.2.2",
    "chai-as-promised": "~8.0.2",
    "jsdoc-to-markdown": "~9.1.3",
    "microbundle": "~0.15.1",
    "mocha": "~11.7.5",
    "typedoc": "^0.28.17",
    "winston": "~3.19.0"
  },
  "dependencies": {
    "@types/node": "^25.3.5",
    "axios": "^1.14.0",
    "dotenv": "~17.3.1",
    "form-data": "^4.0.5",
    "lodash": "~4.17.23",
    "mime-types": "^3.0.2",
    "reversible-map": "~1.0.1",
    "typescript": "^5.9.3"
  }
}
